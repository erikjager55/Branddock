{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Baseline Claude Code config voor Branddock. Persoonlijke overrides in settings.local.json (gitignored). Wijzigingen in dit bestand worden gecommit en delen we met toekomstige sessies.",

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-typecheck.sh",
            "blocking": false,
            "timeout": 60000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-dangerous-bash.sh"
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-guard.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-guard.sh",
            "blocking": false
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-summary.sh",
            "blocking": false
          }
        ]
      }
    ]
  },

  "permissions": {
    "allow": [
      "Bash(npm run dev:*)",
      "Bash(npm run build)",
      "Bash(npm run lint:*)",
      "Bash(npm run test:*)",
      "Bash(npm install)",
      "Bash(npm install --save-dev:*)",
      "Bash(npx tsc --noEmit:*)",
      "Bash(npx tsc:*)",
      "Bash(npx prisma generate)",
      "Bash(npx prisma db push)",
      "Bash(npx prisma validate)",
      "Bash(npx prisma format)",
      "Bash(npx tsx:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git worktree list)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git mv:*)",
      "Bash(git stash:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git checkout -- :*)",
      "Bash(git restore --source=:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git commit -n:*)",
      "Bash(npm publish:*)",
      "Bash(npx prisma migrate reset:*)",
      "Bash(curl:*--data-urlencode:*)"
    ],
    "ask": [
      "Bash(git branch -D:*)"
    ]
  }
}
