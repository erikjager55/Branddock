{
  "manifest_version": 3,
  "name": "Branddock Everywhere",
  "version": "0.2.0",
  "description": "Herschrijf, beantwoord en beoordeel tekst on-brand met je Branddock-workspace — overal in de browser.",
  "permissions": [
    "contextMenus",
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Branddock Everywhere",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
