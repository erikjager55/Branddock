// ─────────────────────────────────────────────────────────────
// Consistent AI Models (Fase I.4)
// ─────────────────────────────────────────────────────────────

model ConsistentModel {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("CreatedConsistentModels", fields: [createdById], references: [id])

  name        String
  slug        String
  description String?               @db.Text
  type        ConsistentModelType
  status      ConsistentModelStatus @default(DRAFT)

  // fal.ai integration
  falModelId        String? // fal.ai model endpoint ID (e.g., "fal-ai/flux-lora")
  falLoraUrl        String? // Trained LoRA weights URL
  falRequestId      String? // fal.ai queue request ID
  generatorEndpoint String? // Generator endpoint (e.g., "fal-ai/flux-lora", "fal-ai/flux-2-lora")
  triggerWord       String? // Trigger word (e.g. "TOK")
  baseModel         String? // "flux-dev-lora" or similar

  // Training config
  trainingConfig      Json? // { steps, learningRate, resolution, ... }
  trainingStartedAt   DateTime?
  trainingCompletedAt DateTime?
  trainingError       String?   @db.Text

  // Visual style context
  stylePrompt    String? @db.Text
  negativePrompt String? @db.Text

  // Style reference fields (for non-trainable types: BRAND_STYLE, PHOTOGRAPHY, ILLUSTRATION)
  modelName        String? // Illustration tool/style name
  modelDescription String? @db.Text // Extended description
  generationParams Json? // Illustration-specific params
  brandContext     Json? // Snapshot of brand context at creation time

  // Illustration style analysis
  styleProfile        Json? // IllustrationStyleProfile (50+ params from AI analysis)
  styleProfileVersion Int     @default(0)
  styleAnalysisStatus String? // PENDING | ANALYZING | COMPLETE | FAILED

  // Metadata
  thumbnailUrl    String?
  sampleImageUrls Json? // String[] — AI-generated samples after training
  usageCount      Int     @default(0)
  isDefault       Boolean @default(false)

  referenceImages ReferenceImage[]
  generations     ConsistentModelGeneration[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId, type])
  @@index([workspaceId, status])
}

model ReferenceImage {
  id                String          @id @default(cuid())
  consistentModelId String
  consistentModel   ConsistentModel @relation(fields: [consistentModelId], references: [id], onDelete: Cascade)

  fileName String
  fileSize Int // bytes
  mimeType String // image/jpeg, image/png, image/webp
  width    Int?
  height   Int?

  // Storage (Cloudflare R2)
  storageKey   String // R2 key: ws_{id}/models/{modelId}/{uuid}.jpg
  storageUrl   String // Signed URL or CDN URL
  thumbnailKey String?
  thumbnailUrl String?

  // Metadata
  caption         String?
  sortOrder       Int     @default(0)
  isTrainingImage Boolean @default(true)

  // Source tracking (AI-generated vs manual upload)
  source      ReferenceImageSource @default(UPLOADED)
  aiProvider  String? // "imagen" or "dalle"
  aiModel     String? // specific model version used
  aiPrompt    String?              @db.Text
  generatedAt DateTime?

  createdAt DateTime @default(now())

  @@index([consistentModelId])
}

model ConsistentModelGeneration {
  id                String          @id @default(cuid())
  consistentModelId String
  consistentModel   ConsistentModel @relation(fields: [consistentModelId], references: [id], onDelete: Cascade)
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById       String
  createdBy         User            @relation("CreatedConsistentModelGenerations", fields: [createdById], references: [id])

  // Generation params
  prompt            String  @db.Text
  negativePrompt    String? @db.Text
  seed              Int?
  width             Int     @default(1024)
  height            Int     @default(1024)
  guidanceScale     Float?
  numInferenceSteps Int?

  // Result
  storageKey   String // R2 key
  storageUrl   String // CDN/signed URL
  thumbnailKey String?
  thumbnailUrl String?

  // Metadata
  generationTimeMs Int?
  aiProvider       String // "replicate"
  aiModel          String // Replicate model version
  cost             Float? // Estimated cost in USD
  mediaAssetId     String? // Link to MediaAsset if saved to library

  // Style validation (Illustration models)
  styleValidationScore   Float? // 0-1 overall style match score
  styleValidationDetails Json? // StyleValidationResult details

  createdAt DateTime @default(now())

  @@index([consistentModelId])
  @@index([workspaceId])
}

