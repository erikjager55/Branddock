// ============================================
// BRANDSTYLE MODELLEN (Fase 3)
// ============================================

model BrandStyleguide {
  id                 String           @id @default(cuid())
  status             StyleguideStatus @default(DRAFT)
  sourceType         StyleguideSource
  sourceUrl          String?
  sourceFileName     String?
  analysisJobId      String?
  analysisStatus     AnalysisStatus   @default(PENDING)
  errorMessage       String?          @db.Text
  // CSS framework / design-system fingerprints recognised during analysis
  // (e.g. ["acss", "elementor"]). Used by the UI to surface provenance
  // and confidence in the extracted brand tokens.
  detectedFrameworks String[]         @default([])

  // Layout-style (Sprint 3 brand-styling-consistency-plan §3c) — bepaalt
  // visuele dichtheid / witruimte / component-variant in PUCK-render.
  // Auto-detected door brandstyle-scraper, user kan overriden in onboarding.
  layoutStyle        LayoutStyle      @default(COMMERCIAL)

  // V2-2 lazy-inference gate: false betekent dat de waarde nog de schema-
  // default is en herinferreerd mag worden door ensureLayoutStyle. True =
  // expliciet inferred-en-gepersist of door user gezet → niet overschrijven.
  // Zonder deze flag kan ensure niet onderscheiden tussen "user heeft
  // COMMERCIAL gekozen" en "schema-default COMMERCIAL nooit veranderd".
  layoutStyleInferred Boolean         @default(false)

  // Verbeterplan Fase B — rendering-profiles uit scraper (alle Json?,
  // nullable additive). Renderer leest deze velden voor brand-specifieke
  // button/spacing/elevation/motion-styling i.p.v. archetype-defaults.
  /** ScrapedButtonStyle[] — primary/secondary/ghost button-samples. */
  buttonProfile       Json?
  /** SpacingProfile — section/card/button/input padding-samples + typical. */
  spacingProfile      Json?
  /** ElevationProfile — box-shadow categorisatie + dominant. */
  elevationProfile    Json?
  /** RadiusProfile — border-radius typical per context. */
  radiusProfile       Json?
  /** MotionProfile — transition+animation duration + dominant easing. */
  motionProfile       Json?
  /** ScrapedTypographyByRole — display/heading/body/label/button styles. */
  typographyProfile   Json?

  // Verbeterplan #5 — per-veld override-flags. False = scraper mag
  // overschrijven bij re-scrape; True = user-set OR expliciet
  // re-scrape-protected. Voor toekomstige brand-onboarding UI.
  buttonProfileOverride       Boolean @default(false)
  spacingProfileOverride      Boolean @default(false)
  elevationProfileOverride    Boolean @default(false)
  radiusProfileOverride       Boolean @default(false)
  motionProfileOverride       Boolean @default(false)
  typographyProfileOverride   Boolean @default(false)
  /** Eén-zin design-philosophy uit AI-analyse (Fase E3 verbeterplan).
   *  "Beschrijf wat dit merk visueel anders maakt — wat MOET behouden bij
   *  rendering". Wordt als brand-context aan content-generation gegeven. */
  designPhilosophy    String? @db.Text

  /** DTS-plan C7 — fixture-samples per content-type (real headlines / CTAs
   *  uit gescrapede bodyText). Puck defaultProps gebruikt deze voor Step 2
   *  preview i.p.v. lorem-ipsum. Shape: { headlines?: string[],
   *  ctaLabels?: string[], featureTitles?: string[], testimonialQuotes?: string[] } */
  fixtureSamples      Json?

  // Pad C Sub-Sprint B — Jung's brand-archetype. AI-classified uit
  // BrandAssetVersion content. Null = nog niet geclassificeerd; renderer
  // valt terug op layoutStyle-only beslissingen.
  archetype           BrandArchetype?
  archetypeConfidence String?  // "high" | "medium" | "low"
  archetypeReasoning  String?  @db.Text  // 1-2 zinnen waarom de classifier dit koos

  // Logo (logoVariations JSON vervangen door StyleguideLogo relatie — Fase 0)
  logos          StyleguideLogo[]
  logoGuidelines String[]
  logoDonts      String[]
  logoSavedForAi Boolean          @default(false)

  // Fonts (nieuw Fase 0 — vervangt primaryFontName/additionalFonts op termijn)
  fonts StyleguideFont[]

  // Colors
  colors           StyleguideColor[]
  colorDonts       String[]
  colorsSavedForAi Boolean           @default(false)
  // Semantic colors: { info: {light, base}, success: {...}, warning: {...}, danger: {...} }
  semanticColors   Json?

  // Typography
  primaryFontName      String?
  primaryFontUrl       String?
  additionalFonts      String[] @default([])
  typeScale            Json?
  typographySavedForAi Boolean  @default(false)

  // Tone of Voice velden verhuisd naar BrandVoiceguide (ADR 2026-05-15).

  // Imagery
  photographyStyle       Json?
  photographyGuidelines  String[]
  illustrationGuidelines String[]
  imageryDonts           String[]
  imagerySavedForAi      Boolean  @default(false)
  brandImages            Json? // Array<{ url, alt, context }>

  // Design Language
  graphicElements          Json?
  graphicElementsDonts     String[]
  patternsTextures         Json?
  iconographyStyle         Json?
  iconographyDonts         String[]
  gradientsEffects         Json?
  layoutPrinciples         Json?
  designLanguageSavedForAi Boolean  @default(false)

  // Visual Language (Vormentaal)
  visualLanguage           Json?
  visualLanguageSavedForAi Boolean @default(false)

  // Spacing tokens (Fase 4 — gesplitst uit Visual System)
  spacingScale Json? // { xs, sm, md, lg, xl } or array
  cornerRadii  Json? // { sm, md, lg, xl, full }
  shadowSystem Json? // Array<{ label, value, intensity }>

  // Semantic tokens (DESIGN.md export — afgeleide rollen door semantic-role-resolver)
  // Shape: { resolved: {...}, overrides?: {...}, diagnostics: {...}, resolvedAt, resolverVersion }
  // Zie src/lib/brandstyle/semantic-role-resolver.ts voor volledige type.
  semanticTokens Json?

  // Kleurcombinaties (Fase 5 brand-fidelity) — WCAG-geverifieerde fg/bg-paren
  // afgeleid uit het palet door buildColorPairings (color-pairings.ts).
  // Shape: Array<{ label, background, foreground, contrastRatio, wcag, usage }>
  colorPairings Json?

  // Raw geobserveerde (tekstkleur " | " effectieve-achtergrond)-paren → count
  // (multi-page bulk-computed-styles). Source-of-truth voor recompute na een
  // manuele kleur-edit, zodat observed dark-mode-combinaties niet degraderen
  // naar gegenereerd. Shape: Record<string, number>.
  observedColorPairs Json?

  // Components (Fase 5 — automatisch gedetecteerd tijdens analyzer run)
  components StyleguideComponent[]

  // History — append-only snapshots per analyzer-run (zie BrandstyleSnapshot model)
  snapshots BrandstyleSnapshot[]

  // Review workflow + Published state (Fase 2)
  reviews     StyleguideReview[]
  published   Boolean            @default(false)
  publishedAt DateTime?

  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?
  lockedBy   User?     @relation("LockedStyleguides", fields: [lockedById], references: [id])

  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([workspaceId])
  @@index([workspaceId])
}

