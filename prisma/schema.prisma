// Pad C Sub-Sprint A — Brand design-system layout-archetype.
// Maps naar concrete design-system primitives (spacing/typography/radius/
// imageStrategy/sectionAlternation) in src/lib/landing-pages/design-system.ts.
enum LayoutStyle {
  MINIMAL       // Stripe, Linear, Dinesen, LINFI, Zwarthout — sparse, premium, serif-display
  EDITORIAL     // Apple product, Tesla — magazine-style, sophisticated, mixed-media
  COMMERCIAL    // Coolblue, Bol.com, HubSpot — conversion-focused, dense info-grid
  EXPERIENTIAL  // Patagonia, Tony's Chocolonely — story-driven, immersive
  PLAYFUL       // Notion marketing, MailerLite — colorful, illustration-heavy
}

// Pad C Sub-Sprint B — Jung's 12 Brand Archetypes (industriestandaard
// voor brand-personality classification). Drijft visuele design-keuzes
// in brand-render-rules.ts: bg-style, typography-emphasis, button-shape,
// micro-copy-tone, etc. AI-classified uit BrandAssetVersion content;
// cached op styleguide; user kan overrulen via onboarding-UI.
enum BrandArchetype {
  INNOCENT       // Coca-Cola, Dove — purity, optimism, simplicity
  EXPLORER       // Patagonia, Jeep — freedom, adventure, individuality
  SAGE           // Google, BBC, McKinsey — wisdom, knowledge, expertise
  HERO           // Nike, BMW — courage, mastery, achievement
  OUTLAW         // Harley-Davidson, Virgin — rebellion, revolution, disruption
  MAGICIAN       // Disney, Apple — transformation, vision, mystery
  REGULAR_GUY    // IKEA, eBay — belonging, down-to-earth, accessibility
  LOVER          // Chanel, Häagen-Dazs — passion, intimacy, sensuality
  JESTER         // Old Spice, M&Ms — joy, humor, lightheartedness
  CARETAKER      // Johnson & Johnson, Volvo — service, protection, nurture
  CREATOR        // Lego, Adobe — innovation, imagination, self-expression
  RULER          // Mercedes, Rolex, LINFI — control, leadership, premium quality
}

