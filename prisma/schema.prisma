  isFeatured     Boolean       @default(false)
  thumbnailUrl   String?
  aiDescription  String?       @db.Text
  aiTags         String[]
  dominantColors String[] // hex values

  // Pattern G2 image-quality-chain (ADR pending) — semantic-search embedding
  // van aiDescription via OpenAI text-embedding-3-small (1536-dim). Beheerd
  // via raw SQL (zelfde patroon als BrandVoiceguide.centroidEmbedding).
  // Gebruikt voor reuse-detection in Canvas Step 2: similar assets in
  // library worden voorgesteld vóór een nieuwe image-generation start.
  embedding         Unsupported("vector(1536)")?
  embeddingComputedAt DateTime?
  source         MediaSource   @default(UPLOAD)
  sourceUrl      String?
  attribution    String? // Pexels/Unsplash credits

  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User      @relation("UploadedMedia", fields: [uploadedById], references: [id])

  productId String?
  product   Product? @relation("ProductMedia", fields: [productId], references: [id], onDelete: SetNull)

  tags        MediaAssetTag[]
  collections MediaCollectionAsset[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([workspaceId, mediaType])
  @@index([workspaceId, category])
  @@index([productId])
}

model MediaTag {
