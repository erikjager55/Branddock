// =============================================================
// BrandstyleSnapshot — historische versies per analyzer-run.
// Adopteert het hyperbrowserai/competitor-tracker patroon: append-only
// storage van canonical DesignSystemModel + scraped data, met hash-based
// dedupe (skip schrijven als tokensHash gelijk aan vorige snapshot).
// Diff-engine in src/lib/brandstyle/snapshots/snapshot-diff.ts vergelijkt
// twee snapshots op token-niveau en produceert een human-readable changelog.
// =============================================================
model BrandstyleSnapshot {
  id         String   @id @default(cuid())
  capturedAt DateTime @default(now())

  // Fingerprints voor fast no-op detectie zonder volledige diff-compute.
  // tokensHash = sha256 van canonical DesignSystemModel JSON.
  // scrapeHash = sha256 van cleaned scraped HTML (optional).
  tokensHash String
  scrapeHash String?

  // Volledige content — JSON blobs voor reconstructie + diffing.
  // tokensJson is de canonical DesignSystemModel (zie src/lib/export/design-system/canonical.ts).
  tokensJson     Json
  scrapedJson    Json?
  semanticTokens Json?

  // Optionele assets — full-page hero screenshot URL voor preview in History tab.
  screenshotUrl String?

  // Metadata
  triggerSource String // 'analyze-url' | 'analyze-pdf' | 'manual' | 'cron'
  triggeredById String?
  triggeredBy   User?   @relation("SnapshotTrigger", fields: [triggeredById], references: [id])
  // Optionele user-set label, bijv. "Pre-rebrand", "Q3 2026 launch"
  notes         String? @db.Text

  brandstyleId String
  brandstyle   BrandStyleguide @relation(fields: [brandstyleId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([brandstyleId, capturedAt])
  @@index([workspaceId])
  @@index([tokensHash])
}

enum FontRole {
  DISPLAY
  UI
  EYEBROW_META
  BODY
}

enum FontSource {
  DETECTED
  UPLOADED
}

enum FontAvailability {
  /**
   * User uploaded the file — always usable.
   */
  UPLOADED
  /**
   * Detected font exists in the Google Fonts catalog — auto-loaded via CDN.
   */
  GOOGLE_FONTS
  /**
   * Detected font is served via Adobe Fonts (Typekit) on the source site.
   * If the user has an Adobe Creative Cloud / Fonts subscription they can
   * paste their kit ID to preview the real file; otherwise they can still
   * upload the woff2.
   */
  ADOBE_FONTS
  /**
   * Detected font is commercial / not on Google Fonts or Adobe Fonts —
   * upload required for use.
   */
  COMMERCIAL
  /**
   * Google Fonts catalog lookup failed or not yet resolved. Treated as commercial.
   */
  UNKNOWN
}

