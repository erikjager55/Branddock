  websiteUrl    String?
  description   String? @db.Text
  tagline       String?
  foundingYear  Int?
  headquarters  String?
  employeeRange String?
  logoUrl       String?

  // Positioning (AI-extracted)
  valueProposition String?  @db.Text
  targetAudience   String?  @db.Text
  differentiators  String[] @default([])
  mainOfferings    String[] @default([])
  pricingModel     String?
  pricingDetails   String?  @db.Text

  // Brand signals (AI-extracted)
  toneOfVoice      String?  @db.Text
  messagingThemes  String[] @default([])
  visualStyleNotes String?  @db.Text

  // SWOT
  strengths  String[] @default([])
  weaknesses String[] @default([])

  // Online presence
  socialLinks    Json?
  hasBlog        Boolean?
  hasCareersPage Boolean?

  // Score
  competitiveScore Int?

  // Metadata
  tier          CompetitorTier   @default(DIRECT)
  status        CompetitorStatus @default(DRAFT)
  source        String           @default("MANUAL")
  lastScrapedAt DateTime?
  analysisData  Json?

  // Lock
  isLocked   Boolean   @default(false)
  lockedAt   DateTime?
  lockedById String?
  lockedBy   User?     @relation("LockedCompetitors", fields: [lockedById], references: [id])

  // Monitoring (Fase 4 voorbereid — default OFF, geen runtime-impact tot Brandclaw cron actief)
  monitoringEnabled   Boolean             @default(false)
  monitoringFrequency MonitoringFrequency @default(WEEKLY_LIGHT)
  nextScheduledScanAt DateTime?

  // Aggregaten voor snelle UI zonder join (analoog aan ContentFidelityScore.findingsCount)
  snapshotCount               Int @default(0)
  unacknowledgedActivityCount Int @default(0)

  // Relations
  workspaceId    String
  workspace      Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdById    String?
  createdBy      User?                   @relation("CreatedCompetitors", fields: [createdById], references: [id])
  linkedProducts CompetitorProduct[]
  snapshots      CompetitorSnapshot[]
  activities     CompetitorActivity[]
  contentItems   CompetitorContentItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@index([workspaceId, tier])
  @@index([monitoringEnabled, nextScheduledScanAt])
}

model CompetitorProduct {
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  productId    String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([competitorId, productId])
}

// =============================================================
// Competitor historie — Snapshot/Activity/ContentItem
// Volgt het BrandstyleSnapshot patroon (zie regel 1853-1859):
// append-only storage met hash-based dedupe. Diff-engine in
// src/lib/competitors/diff-engine.ts produceert CompetitorActivity
// records uit twee opeenvolgende snapshots. Zie ADR
// 2026-05-08-competitor-snapshot-historie voor rationale.
// =============================================================

enum SnapshotTriggerSource {
  MANUAL // user clicked refresh
  CRON_LIGHT // weekly homepage + tagline + top-3 blogposts scan
  CRON_DEEP // monthly full re-extraction met alle Fase 2 prompts
  API // future: webhook/integratie
}

enum CompetitorSignalSource {
  MANUAL
  WEBSCRAPE
  EXA
  RSS
  WAYBACK
  REVIEWS
  GOOGLE_ALERT
}

enum CompetitorActivityType {
  // Positioning shifts
  TAGLINE_CHANGED
  VALUE_PROP_CHANGED
  TARGET_AUDIENCE_CHANGED
  CATEGORY_REPOSITIONING

  // Product / commercial
  NEW_PRODUCT
  PRODUCT_REMOVED
  PRICING_CHANGED
  NEW_OFFERING

  // Content cadence
  NEW_BLOG_POST
  NEW_PRESS_RELEASE
  NEW_CASE_STUDY
  NEW_FORMAT_EMERGING

  // Organisational signals
  HIRING_SIGNAL
  HEADCOUNT_RANGE_CHANGED
  FUNDING_EVENT
  LEADERSHIP_CHANGE

  // Brand surface
  VISUAL_REBRAND
  SOCIAL_PRESENCE_CHANGE

  // Workspace lifecycle (manual)
  STATUS_CHANGED
  TIER_CHANGED
  USER_ANNOTATED
}

enum ActivitySeverity {
  INFO
  NOTABLE
  MAJOR
}

enum ContentFormat {
  BLOG_POST
  PRESS_RELEASE
  CASE_STUDY
  EBOOK
  WEBINAR
  PODCAST
  VIDEO
  SOCIAL_POST
  DOC
  TOOL
  EVENT
  OTHER
}

enum MonitoringFrequency {
  OFF
  WEEKLY_LIGHT
  BIWEEKLY_LIGHT
  MONTHLY_DEEP
  QUARTERLY_DEEP
}

model CompetitorSnapshot {
  id         String   @id @default(cuid())
  capturedAt DateTime @default(now())

  // Fast no-op detection (analoog aan BrandstyleSnapshot.tokensHash/scrapeHash)
  // contentHash = sha256 van canonical extracted-fields JSON
  // scrapeHash  = sha256 van cleaned scraped HTML/markdown bundle
  contentHash String
  scrapeHash  String?

  // Volledige extracted-state — voor reconstructie + diffing.
  // Mirror van Competitor's AI-extracted velden + raw-scrape bundle.
  extractedJson Json
  scrapedJson   Json?
  embeddings    Json?

  // Herkomst
  triggerSource SnapshotTriggerSource
  signalSource  CompetitorSignalSource
  triggeredById String?
  triggeredBy   User?                  @relation("CompetitorSnapshotTrigger", fields: [triggeredById], references: [id])

  // Optionele audit
  notes  String? @db.Text
  errors Json?

  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  activities            CompetitorActivity[]
  firstSeenContentItems CompetitorContentItem[] @relation("ContentItemFirstSeenSnapshot")

  @@unique([competitorId, contentHash])
  @@index([competitorId, capturedAt])
  @@index([workspaceId, capturedAt])
  @@index([contentHash])
}

model CompetitorActivity {
  id       String                 @id @default(cuid())
  type     CompetitorActivityType
  severity ActivitySeverity       @default(INFO)

  // Diff-payload: gestandaardiseerde voor/na shape per type.
  // Voor TAGLINE_CHANGED: { before: "...", after: "..." }
  // Voor NEW_BLOG_POST: { contentItemId, title, url, publishedAt }
  // Voor PRICING_CHANGED: { fields: ["pricingModel"], before, after }
  diffPayload Json
  summary     String @db.Text

  // Detectie-context
  detectedAt      DateTime @default(now())
  detectionMethod String // "hash-diff" | "ai-classified" | "manual" | "rss-feed"
  confidence      Float?

  // Linkage — minstens snapshot OF manual reference
  snapshotId   String?
  snapshot     CompetitorSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  competitorId String
  competitor   Competitor          @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // Surfaced/dismissed by user
  acknowledgedAt   DateTime?
  acknowledgedById String?
  acknowledgedBy   User?     @relation("CompetitorActivityAcknowledger", fields: [acknowledgedById], references: [id])

  @@index([competitorId, detectedAt])
  @@index([workspaceId, detectedAt])
  @@index([workspaceId, type, detectedAt])
  @@index([competitorId, severity, acknowledgedAt])
}

model CompetitorContentItem {
  id           String        @id @default(cuid())
  url          String
  urlHash      String
  title        String
  excerpt      String?       @db.Text
  format       ContentFormat
  publishedAt  DateTime?
  discoveredAt DateTime      @default(now())

  // Thematische tagging — voor §6.2 content-gap matrix.
  themes   String[] @default([])
  language String?

  // Versie van de discovery/classifier-pipeline die dit item produceerde.
  // Maakt toekomstige re-discovery na format-classifier upgrades mogelijk.
  discovererVersion Int @default(1)

  // 1536-dim embedding voor semantic content-gap analysis — managed via raw SQL only
  // (zelfde patroon als AgentMemory.embedding). Producer komt in vervolg-task
  // competitor-content-item-discovery; blijft null in Fase 1.
  embedding Unsupported("vector(1536)")?

  // Eerste snapshot waarin dit item werd gezien (voor "nieuw sinds vorige scan").
  firstSeenSnapshotId String?
  firstSeenSnapshot   CompetitorSnapshot?    @relation("ContentItemFirstSeenSnapshot", fields: [firstSeenSnapshotId], references: [id], onDelete: SetNull)
  signalSource        CompetitorSignalSource

  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  workspaceId  String
  workspace    Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([competitorId, urlHash])
  @@index([competitorId, publishedAt])
  @@index([workspaceId, format, publishedAt])
  @@index([workspaceId, discoveredAt])
}

// Per-feature AI model configuration (overrides defaults per workspace)
model WorkspaceAiConfig {
  id          String    @id @default(cuid())
  workspaceId String
  featureKey  String // e.g. "persona-chat", "campaign-strategy", "trend-synthesis"
  provider    String // "anthropic" | "openai" | "google"
  model       String // e.g. "claude-sonnet-4-5-20250929", "gpt-4o", "gemini-3.1-pro-preview"
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, featureKey])
  @@map("workspace_ai_config")
}

