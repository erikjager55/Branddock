// =============================================================
// FeatureReport — /feature slash command in Brand Assistant
//
// A feature request submitted by a (test) user from within the app.
// Workspace-scoped so we know which client asked for it. Mirrors
// BugReport, minus AI analysis. Developer-only triage under
// Settings > Developer > Feature Triage. Intentionally separate from
// the global FeatureRequest/FeatureVote voting board on the Help page.
// =============================================================

model FeatureReport {
  id          String  @id @default(cuid())
  page        String // activeSection value where the request was made
  title       String // short summary of the requested feature
  description String  @db.Text
  impact      String  @default("useful") // nice-to-have | useful | important | critical (user-perceived)
  screenshot  String? // optional URL / mockup reference
  status      String  @default("open") // open | planned | in_progress | shipped | declined
  notes       String? @db.Text // developer triage notes

  resolvedAt   DateTime?
  resolvedById String?
  resolvedBy   User?     @relation("FeatureResolver", fields: [resolvedById], references: [id])

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
}

// =============================================================
// ChatFeedback — /feedback slash command in Brand Assistant
//
// User feedback on an AI-generated response. Captures a snapshot of
// the assistant message so the feedback stays meaningful even if the
// conversation moves on. Developer-only triage under
// Settings > Developer > Feedback.
// =============================================================

model ChatFeedback {
  id String @id @default(cuid())

  // What the feedback is about
  page           String? // activeSection where the user was when giving feedback
  conversationId String? // ClawConversation.id when available
  messageId      String? // Local assistant message id (client-side UUID)
  messageContent String? @db.Text // snapshot of the assistant reply

  // The feedback itself
  sentiment String // 'positive' | 'neutral' | 'negative'
  tags      String[] // subset of: inaccurate, off-brand, too-verbose, too-generic, unhelpful, other
  comment   String   @db.Text

  // AI analysis (mirror of BugReport.aiSuggestion/aiStatus)
  aiSuggestion String? @db.Text
  aiStatus     String  @default("pending") // pending | analyzing | ready | failed

  // Triage
  status       String    @default("new") // 'new' | 'reviewed' | 'actioned' | 'dismissed'
  reviewedById String?
  reviewedBy   User?     @relation("ChatFeedbackReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  notes        String?   @db.Text

  // Scope
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId])
  @@index([status])
  @@index([sentiment])
}

// =============================================================
// Campaign Send — Emailit-powered email campaign delivery (4.2 step 4)
//
// Represents a single send of an email deliverable to a list of
// recipients. Webhook events update the stats counters.
// =============================================================

enum CampaignSendStatus {
  DRAFT
  QUEUED
  SENDING
  COMPLETED
  PARTIAL
  FAILED
  CANCELLED
}

model CampaignSend {
  id String @id @default(cuid())

  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  status  CampaignSendStatus @default(DRAFT)
  subject String

  // Recipients — either an inline list or an Emailit audience id.
  recipientEmails   String[] @default([])
  emailitAudienceId String?
  recipientCount    Int      @default(0)

  // Emailit correlation — one send id per recipient (bulk POST /emails loop).
  emailitSendIds String[] @default([])

  // Stats (mutated atomically by webhook handler).
  deliveredCount    Int @default(0)
  openedCount       Int @default(0)
  clickedCount      Int @default(0)
  bouncedCount      Int @default(0)
  complainedCount   Int @default(0)
  unsubscribedCount Int @default(0)
  failedCount       Int @default(0)

  // Meta
  sentById     String?
  sentBy       User?     @relation("CampaignSendSender", fields: [sentById], references: [id], onDelete: SetNull)
  errorMessage String?   @db.Text
  scheduledAt  DateTime?
  startedAt    DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deliverableId])
  @@index([workspaceId, status])
  @@index([emailitSendIds])
}

// =============================================================
// Agent Memory — pgvector-backed long-term memory (4.3)
//
// Supports the future Brandclaw agent loop. Each memory stores a
// 1536-dim embedding (OpenAI text-embedding-3-small) of a content
// snippet plus metadata used for recall ranking:
//   - confidence   how strongly the agent trusts the memory (0-1)
//   - decayWeight  freshness, lowered by age, reinforced on access
//   - accessCount  how often this memory has been recalled
//
// Vector column is Unsupported in Prisma; mutations and similarity
// queries run via raw SQL in src/lib/agents/memory.ts.
// =============================================================

enum AgentMemoryType {
  OBSERVATION
  PREFERENCE
  DECISION
  FACT
  OUTCOME
}

model AgentMemory {
  id String @id @default(cuid())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  content    String          @db.Text
  memoryType AgentMemoryType

  // 1536-dim embedding — managed via raw SQL only
  embedding Unsupported("vector(1536)")?

  confidence  Float @default(1.0)
  decayWeight Float @default(1.0)

  // Access tracking — reinforces memories the agent keeps using.
  accessCount    Int       @default(0)
  lastAccessedAt DateTime?

  // Provenance / metadata
  source   String?
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, memoryType])
  @@index([workspaceId, createdAt])
}

// =============================================================
// Agent Job Queue (4.4)
//
// Persistent job queue for deferred / recurring / retryable work
// triggered by the Brandclaw agent or external webhooks. Processed
// by the /api/cron/run-jobs endpoint on a Vercel Cron schedule —
// DB polling keeps the design serverless-friendly. BullMQ can swap
// in later via the queue abstraction when a dedicated worker
// process becomes feasible.
// =============================================================

enum AgentJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRY
}

enum AgentJobType {
  MEMORY_DECAY
  CAMPAIGN_SEND_FOLLOWUP
  TREND_SCAN_WORKSPACE
  AGENT_TASK
  HEARTBEAT
  BRANDSTYLE_SNAPSHOT_CLEANUP
}

model AgentJob {
  id String @id @default(cuid())

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  type     AgentJobType
  status   AgentJobStatus @default(PENDING)
  priority Int            @default(100)

  payload      Json?
  result       Json?
  errorMessage String? @db.Text

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  attempts      Int       @default(0)
  maxAttempts   Int       @default(3)
  nextAttemptAt DateTime?

  idempotencyKey String? @unique

  triggeredBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([type, status])
  @@index([workspaceId, status])
}

// =============================================================
// CONTINUOUS LEARNING LOOP (sessie 2 — leerlus-werkstroom 2026-05-05)
// =============================================================
//
// Vijf modellen die samen de leerlus-fundament vormen:
// - BrandContextSnapshot : frozen brand-context per AI-call (cat 2a)
// - AICallSnapshot       : frozen call-payload per AI-call (cat 2b/c gemerged)
// - AICallTrace          : per-call instance, polymorf naar parent-entity (cat 2)
// - ContentFidelityScore : 3-pillar + 6-criteria scoring per content-versie (cat 6)
// - LearningEvent        : unified event-log voor cross-cutting queries (cat 9)
//
// Zie: IMPLEMENTATIEPLAN-LEARNING-LOOP.md voor architectuur-rationale.
// Zie: branddock-learning-loop-decisions.md (memory) voor design-beslissingen.
//
// NOG TOE TE VOEGEN (apart, na verificatie schema valideert):
// - `primaryCallTraceId String?` op 10 generatie-modellen (Deliverable,
//   DeliverableComponent, ExplorationSession, TrendResearchJob, BrandAudit,
//   AlignmentScan, AIPersonaAnalysisSession, PersonaChatMessage, ImproveSuggestion)
//   ContentVersion krijgt deze FK óók (al deels via fidelityScores back-relation).
// =============================================================

model BrandContextSnapshot {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /**
   * sha256 of canonical-stringified content. Dedup-key.
   */
  contentHash String

  /**
   * Volledige BrandContextBlock zoals returned door getBrandContext().
   * Bevat alle 12 brand assets, persona's, producten, geactiveerde trends,
   * competitors, styleguide, brand voices, consistent models.
   */
  content Json

  createdAt DateTime @default(now())

  callTraces AICallTrace[]

  @@unique([workspaceId, contentHash])
  @@index([workspaceId])
}

model AICallSnapshot {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /**
   * sha256 of canonical-stringified payload. Dedup-key.
   */
  contentHash String

  /**
   * Volledige call-payload: model + messages + tools + params + providerExtensions.
   * Provider-agnostiek. Hash op canonical-stringify.
   */
  payload Json

  /**
   * Provenance — hoe is deze prompt geproduceerd?
   */
  sourceType       String // "ts-builder" | "db-config" | "inline"
  sourceIdentifier String // file:function for TS, ExplorationConfigId for DB
  gitSha           String? // env var bij call-tijd, NULL voor db-config

  /**
   * Semver van prompt-template (content-test sub-sprint #5.A foundation).
   * Gevuld uit PROMPT_VERSIONS registry in src/lib/ai/prompt-version-registry.ts.
   * Nullable voor backwards-compat met pre-#5.A records.
   */
  promptVersion String?

  createdAt DateTime @default(now())

  callTraces AICallTrace[]

  @@unique([workspaceId, contentHash])
  @@index([workspaceId])
  @@index([sourceIdentifier])
  @@index([promptVersion])
}

model AICallTrace {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  aiCallSnapshotId String
  aiCallSnapshot   AICallSnapshot @relation(fields: [aiCallSnapshotId], references: [id], onDelete: Cascade)

  brandContextSnapshotId String?
  brandContextSnapshot   BrandContextSnapshot? @relation(fields: [brandContextSnapshotId], references: [id], onDelete: SetNull)

  /**
   * Polymorf — geen FK-constraint. Cleanup-job nodig voor orphans.
   */
  parentEntityType String // "Deliverable" | "ContentVersion" | "ExplorationSession" | ...
  parentEntityId   String

  /**
   * Voor multi-call paden (strategy-pipeline 8+ calls, tool-use loops).
   * Single-call paden hebben callOrder=0.
   */
  callOrder Int @default(0)

  /**
   * Response-metadata: tokens, latency, stopReason, errorCode, cache-info.
   */
  responseMetadata Json

  /**
   * Layer 1 generic property-evals results (content-test #5.A foundation).
   * Array van { check, pass, severity, reason, evidence? } per generated variant.
   * Nullable voor backwards-compat + voor calls die geen variants produceren
   * (zoals strategy-rationale-only calls).
   */
  propertyEvalResults Json?

  /**
   * Wiring checkpoint-gate warnings (content-test #6.A wiring-gates). Array
   * van warn-severity gate-failures die niet blocked maar wel gelogd zijn.
   * Pre-#6.A altijd null.
   */
  gateWarnings Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  fidelityScores       ContentFidelityScore[]
  visualFidelityScores ContentVisualFidelityScore[]

  @@index([workspaceId])
  @@index([parentEntityType, parentEntityId, callOrder])
  @@index([aiCallSnapshotId])
  @@index([brandContextSnapshotId])
}

/**
 * G8 — multimodal visual fidelity score per generated image.
 * Mirrors ContentFidelityScore but FK to DeliverableComponent because each
 * generated image is an atomic visual unit with its own brand-coherence
 * score. One DeliverableComponent (with imageUrl) can have multiple scores
 * over time (regenerate, multi-judge).
 * Composition: deterministic color alignment + AI-judge visual evaluation.
 * Threshold defaults to 70 — same publishable bar as text fidelity.
 */
model ContentVisualFidelityScore {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /**
   * Component holds the imageUrl that was scored.
   */
  componentId String
  component   DeliverableComponent @relation(fields: [componentId], references: [id], onDelete: Cascade)

  /**
   * Snapshot of the URL at scoring time — the component may regenerate later.
   */
  imageUrl String

  /**
   * NULL voor pure-deterministische scores (geen AI-call).
   */
  judgeCallTraceId String?
  judgeCallTrace   AICallTrace? @relation(fields: [judgeCallTraceId], references: [id], onDelete: SetNull)

  judgeIdentifier String

  /**
   * 0-100 weighted average van color alignment + AI-judge dimensies.
   */
  compositeScore Float

  /**
   * colorAlignment: { score, matchedColors[{generatedHex, brandHex, deltaE}], unmatchedColors[hex] }
   */
  colorAlignment Json

  /**
   * aiJudgeDimensions: { 'style-coherence': {score, rationale}, 'mood-fit': {...}, ... }
   */
  aiJudgeDimensions Json

  /**
   * thresholdMet shortcut.
   */
  thresholdMet Boolean @default(false)

  /**
   * Versie van de scoring-logica voor reproducibility.
   */
  scorerVersion String?

  scoredAt DateTime @default(now())

  @@index([workspaceId])
  @@index([componentId])
  @@index([judgeCallTraceId])
  @@index([workspaceId, scoredAt])
}

model ContentFidelityScore {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  contentVersionId String
  contentVersion   ContentVersion @relation(fields: [contentVersionId], references: [id], onDelete: Cascade)

  /**
   * NULL voor deterministische scores (geen AI-call).
   */
  judgeCallTraceId String?
  judgeCallTrace   AICallTrace? @relation(fields: [judgeCallTraceId], references: [id], onDelete: SetNull)

  /**
   * Human-readable label: "deterministic-rule-engine-v1" | "claude-judge-fidelity" | "human:userId".
   */
  judgeIdentifier String

  /**
   * 0-100, weighted average van pillars.
   */
  compositeScore Float

  /**
   * PillarScores shape: { strategic: {score, weight}, audience: {score, weight}, execution: {score, weight} }
   */
  pillarScores Json

  /**
   * SubCriteriaScores shape: 6 keys, elk { score, pillar, source, rationale? }
   */
  subCriteriaScores Json

  /**
   * RuleViolation[]: { ruleId, severity, message, snippet?, source, pillar? }
   */
  ruleViolations Json

  /**
   * compositeScore >= compositeThreshold (uit fidelity-criteria.ts).
   */
  thresholdMet Boolean @default(false)

  /**
   * Versie van de scoring-logica voor reproducibility.
   */
  scorerVersion String?

  /**
   * ADR-1: nullable aggregate-counter voor snelle UI-counts zonder join.
   * null = pre-Δ-1 row (geen findings-pad gerunde); 0 = run zonder findings.
   */
  findingsCount Int?

  /**
   * ADR-1: 1-N relation naar gestructureerde bevindingen.
   */
  findings BrandReviewFinding[]

  scoredAt DateTime @default(now())

  @@index([workspaceId])
  @@index([contentVersionId])
  @@index([judgeCallTraceId])
  @@index([workspaceId, scoredAt])
}

// ============================================================
// Ad Quality Validation Layer (Fase A.5 per ADR
// 2026-05-22-ad-quality-validation) — platform-bewuste kwaliteits-
// score per ad-deliverable variant, gebaseerd op L1 static rules +
// L2 AI-judge, weighted naar 0-100 score + Google Ad Strength label
// (Poor/Average/Good/Excellent). Roll-out: search-ad eerst (A.5.1),
// dan display-ad (RDA), facebook-ad, linkedin-ad.
// ============================================================

model AdQualityScore {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  variantIndex Int // 0 = Variant A, 1 = Variant B
  platform     String // "google" | "meta" | "linkedin" | "native"
  contentType  String // "search-ad" | "display-ad" | "facebook-ad" | "linkedin-ad" | "native-ad" | "retargeting-ad"

  /**
   * 0-100 weighted aggregate van L1 + L2 (per spec sectie 6.1).
   */
  overallScore Int

  /**
   * "poor" | "average" | "good" | "excellent" — matched aan Google
   * Ad Strength labels via thresholds 0-25 / 26-50 / 51-75 / 76-100.
   */
  ratingLabel String

  /**
   * L1 deterministic rule results — array van { ruleId, category,
   * status, message, suggestion?, fieldGroup? }.
   */
  l1Results Json

  /**
   * L2 AI-judge results — { dimensions: { [name]: { score, rationale,
   * suggestion } }, summary } OR { error, fallback: true } bij L2-failure.
   */
  l2Results Json

  /**
   * SHA-256 over canonical-JSON van (groups + primaryKeyword +
   * platform + contentType + ruleVersion + judgeVersion + weightsVersion)
   * voor idempotency-check. Zie content-hash.ts.
   */
  contentHash String

  generatedAt DateTime @default(now())

  @@unique([deliverableId, variantIndex, contentHash])
  @@index([deliverableId])
  @@index([platform, contentType])
}

// ============================================================
// Fase B — Ad Publishing pipeline (per ADR/spec ad-publishing.md).
// 3 models: ConnectedAdAccount (workspace ↔ Meta/LinkedIn/Google
// ad-account met encrypted OAuth tokens), AdCampaign (één row per
// gepubliceerd creative naar een platform), AdMetricSnapshot
// (lege table voor Fase C measurement; structuur klaar zodat
// fetch-job later additief is, geen migratie nodig).
// ============================================================

model ConnectedAdAccount {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  platform          String // "meta" | "linkedin" | "google"
  externalAccountId String // Meta: act_1234, LinkedIn: sponsoredAccount URN, Google: customer-id
  accountName       String?
  currency          String? // ISO 4217 (EUR/USD)
  timezone          String? // IANA timezone (Europe/Amsterdam)

  // Encrypted with TOKEN_ENCRYPTION_KEY at write-time, decrypted via helper at read-time.
  accessTokenEncrypted  String
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?

  scopes           String[] // gegranteerde OAuth scopes
  status           String // "active" | "expired" | "revoked" | "error"
  lastRefreshedAt  DateTime?
  lastErrorMessage String?

  connectedById String
  connectedBy   User   @relation("ConnectedAdAccountConnector", fields: [connectedById], references: [id])

  campaigns AdCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, platform, externalAccountId])
  @@index([workspaceId, platform, status])
}

model AdCampaign {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  connectedAccountId String
  connectedAccount   ConnectedAdAccount @relation(fields: [connectedAccountId], references: [id], onDelete: Restrict)

  // External IDs — naming volgt Meta-conventie, abstract genoeg voor LinkedIn/Google.
  externalCampaignId String? // Meta campaign-id, LinkedIn campaign-id, Google campaign resource name
  externalAdSetId    String? // Meta ad-set-id, LinkedIn campaign-group, Google ad-group
  externalCreativeId String? // Meta creative-id, LinkedIn creative URN, Google ad-asset
  externalAdId       String? // Meta ad-id, LinkedIn creative-id, Google ad-id

  status           String // "draft" | "publishing" | "active" | "paused" | "rejected" | "failed"
  statusMessage    String? @db.Text // platform reason bij rejected/failed
  lastStatusSyncAt DateTime? // bumped door status-sync job, NULL bij eerste publish

  publishedAt       DateTime?
  publishedByUserId String?
  publishedByUser   User?     @relation("AdCampaignPublisher", fields: [publishedByUserId], references: [id])

  // Snapshot van wat naar de API ging, voor audit + later re-submission
  publishedPayload Json?

  metrics AdMetricSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deliverableId])
  @@index([connectedAccountId, status])
  @@index([externalCampaignId])
}

model AdMetricSnapshot {
  id         String     @id @default(cuid())
  campaignId String
  campaign   AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  capturedAt  DateTime
  windowStart DateTime // metric-bucket start
  windowEnd   DateTime // metric-bucket end

  impressions     Int?
  reach           Int?
  clicks          Int?
  ctr             Float?
  cpm             Float?
  cpc             Float?
  spend           Float?
  conversions     Int?
  conversionValue Float?

  // Platform-specifieke breakdowns (Meta engagement breakdown, LinkedIn lead-form fills,
  // Google quality-score). Query-able via Postgres JSON-operatoren zonder schema-migratie.
  raw Json

  createdAt DateTime @default(now())

  @@unique([campaignId, windowStart, windowEnd])
  @@index([campaignId, capturedAt])
}

// ============================================================
// Δ-1 Content Review — extern paste-in/URL/file pad voor F-VAL
// (ADR-1 BrandReviewFinding model + ContentReviewLog session-metadata)
// ============================================================

enum BrandReviewSeverity {
  HIGH
  MEDIUM
  LOW
}

enum FindingCategory {
  /**
   * §5.1 — toon, persoonsverschuiving, genre-misfit
   */
  VOICE
  /**
   * §5.2 — synoniem-zwerm, brand-vocabulary onderbenut
   */
  TERMINOLOGY
  /**
   * §5.3 — superlatieven, vage kwaliteit, comparatieven
   */
  CLAIMS
  /**
   * §5.4 — sentence/title case, number-formatting, punctuatie
   */
  STYLE
  /**
   * §5.5 — kern-narrative, positionering, regulering
   */
  BUSINESS
  /**
   * EN-only initieel — AI-generated content telltales
   */
  AI_TELL
}

/**
 * Per ADR-1: gestructureerde finding row. XOR FK pattern — een finding hoort
 * bij een ContentFidelityScore (gegenereerde content) OF bij een
 * ContentReviewLog (externe paste-in/URL/file). XOR is afgedwongen op
 * Postgres-niveau via raw CHECK constraint (zie migration
 * `20260508130000_add_brand_review_finding_and_content_review_log`).
 */
model BrandReviewFinding {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // XOR — exactly one of these is non-null
  fidelityScoreId    String?
  fidelityScore      ContentFidelityScore? @relation(fields: [fidelityScoreId], references: [id], onDelete: Cascade)
  contentReviewLogId String?
  contentReviewLog   ContentReviewLog?     @relation(fields: [contentReviewLogId], references: [id], onDelete: Cascade)

  /**
   * "section + first 4 words" of "char-offset range"
   */
  location    String
  severity    BrandReviewSeverity
  category    FindingCategory
  description String              @db.Text
  suggestion  String?             @db.Text
  /**
   * Voor top-issues: voor/na in volledige zinscontext
   */
  beforeText  String?             @db.Text
  afterText   String?             @db.Text
  /**
   * Citation-keys, rule-IDs, confidence — provenance metadata
   */
  evidence    Json?

  createdAt DateTime @default(now())

  @@index([fidelityScoreId, severity])
  @@index([contentReviewLogId, severity])
  @@index([workspaceId, createdAt])
}

/**
 * Δ-1 Content Review session metadata. Per beslispunt 4 idea-doc: 90-dagen
 * default retention via `retainUntil` + nightly cron-cleanup. PII-bewust:
 * `sourceContent` veld bevat paste-in tekst die confidentieel kan zijn —
 * encryption-at-rest is workspace-toggle in privacy-dpa-hooks LATER-task.
 */
model ContentReviewLog {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /**
   * Optioneel: system-runs (e.g. scheduled audit) hebben geen user.
   */
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /**
   * 'paste' | 'url' | 'file' — bron van de gereviewde content.
   */
  sourceType    String
  /**
   * Volledige tekst (paste OF na ingest van URL/file). Truncate ≥50KB.
   */
  sourceContent String  @db.Text
  /**
   * Originele URL bij sourceType='url' — voor source-attribution.
   */
  sourceUrl     String?
  /**
   * Optionele explicit locale-override (anders: BrandVoiceguide.contentLocale via resolver).
   */
  language      String?

  /**
   * Snapshot van F-VAL output (immutable per ADR-2 reproducibility).
   */
  compositeScore   Float
  pillarScoresJson Json
  scorerVersion    String?

  /**
   * Per ADR-1: findings live in BrandReviewFinding 1-N relation.
   */
  findings BrandReviewFinding[]

  durationMs  Int
  /**
   * Default = createdAt + 90 days (per beslispunt 4). Cron-cleanup ruimt op.
   */
  retainUntil DateTime
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([retainUntil])
}

model LearningEvent {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /**
   * Optioneel — system-events (cron, agent) hebben geen userId.
   */
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  /**
   * LearningEventType uit src/types/learning-loop.ts.
   * String, geen DB-enum — uitbreiden vereist alleen TS-update.
   */
  eventType String

  /**
   * Polymorf — geen FK-constraint.
   */
  entityType String
  entityId   String

  /**
   * Event-specifieke payload. Shape per type via TS discriminated union.
   */
  data Json?

  /**
   * Edit-distance signal voor `content.edited` events (content-test #6.B).
   * Genormaliseerd Levenshtein 0.0-1.0 (1 = volledig herschreven).
   * > 0.20 = soft-negative signal voor regression-corpus filter.
   * Null voor non-edit events.
   */
  editDistance Float?

  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([workspaceId, timestamp])
  @@index([workspaceId, userId, timestamp])
  @@index([entityType, entityId, timestamp])
  @@index([workspaceId, eventType, timestamp])
  @@index([workspaceId, eventType, editDistance])
}

// ============================================================
// F-VAL: pijler 3 (anti-AI-tell + rules) + workspace fidelity config
// Zie docs/fidelity/F-VAL-plan-v0.5.md
// ============================================================

enum BrandRuleType {
  /**
   * Verboden woord/frase — exact match of regex
   */
  FORBIDDEN_WORD
  /**
   * Verplichte formulering in specifieke context
   */
  REQUIRED_PHRASE
  /**
   * Kwantitatieve grens (max zinslengte, max bullets, etc)
   */
  STYLE_LIMIT
  /**
   * Output moet expliciete verwijzing bevatten naar gekozen pijler/waarde
   */
  PILLAR_REFERENCE
}

enum HumanVoiceMode {
  /**
   * HVD niet geïnjecteerd — rauwe Branddock + BVD output
   */
  OFF
  /**
   * HVD wordt geïnjecteerd naast BVD in alle generaties
   */
  BASELINE
  /**
   * BASELINE + post-generatie tell-check; auto-rewrite bij AI_LEANING / PURE_AI verdict
   */
  STRICT
}

/**
 * Per-workspace brand rules (pijler 3c uit F-VAL v0.5).
 * Aanvullend op de generieke Human Voice Directive — workspace-eigenaars
 * voegen hier merk-specifieke verboden woorden, verplichte formuleringen
 * en stijlregels toe. Auto-import vanuit BrandPersonality.wordsWeAvoid
 * is voorzien als seed bij workspace creation.
 */
model BrandRule {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  ruleType       BrandRuleType
  /**
   * Pattern: literal string of regex source (afhankelijk van patternIsRegex)
   */
  pattern        String
  patternIsRegex Boolean       @default(false)

  /**
   * Optionele uitleg voor de gebruiker bij detectie
   */
  message String?

  /**
   * info | warning | error — bepaalt hoe streng de violation telt in pijler 3 score
   */
  severity String @default("warning")

  /**
   * Lege array = van toepassing op alle content types. Anders alleen op
   * deliverables met deliverableTypeId in deze lijst.
   */
  contentTypeFilter String[] @default([])

  isActive Boolean @default(true)

  /**
   * Voor audit: waar kwam deze rule vandaan?
   * "manual" | "auto:wordsWeAvoid" | "csv-import" | "system"
   */
  source String @default("manual")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workspaceId, isActive])
  @@index([workspaceId, ruleType])
}

/**
 * Per-workspace fidelity scoring configuratie (pijler 1/2/3 weights,
 * Human Voice mode, content-type opt-outs).
 * Eén record per workspace (unique). Auto-aangemaakt bij workspace
 * creation via databaseHook met defaults.
 */
model FidelityConfig {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // ─── Composite weights (sum should equal 1.0) ───
  /**
   * /**
   * /**
   * /** Pijler 1 — style scoring op bestaande BrandPersonality data
   */
  styleWeight Float @default(0.35)
  /**
   * Pijler 2 — G-Eval rubric judge
   */
  judgeWeight Float @default(0.45)
  /**
   * Pijler 3 — anti-tell + BrandRule compliance
   */
  ruleWeight  Float @default(0.20)

  // ─── Pijler 2 rubric weights (6 dimensies, sum 1.0) ───
  /**
   * /**
   * /**
   * /** Shape: { strategicAnchoring: 0.20, audienceFit: 0.15, brandRecognition: 0.15,
   * antiPattern: 0.30, coherence: 0.10, concreteness: 0.10 }
   */
  rubricWeights Json?

  // ─── Pijler 3 anti-tell laag ───
  humanVoiceMode HumanVoiceMode @default(BASELINE)

  /**
   * Drempel voor AI_LEANING verdict — boven dit positie-getal triggert STRICT-mode rewrite
   */
  aiLeaningThreshold Int @default(30)

  // ─── Per content-type opt-outs ───
  /**
   * /**
   * /**
   * /** Lege array = fidelity scoring actief voor alle types
   */
  disabledContentTypes String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =============================================================
// BRAND VOICEGUIDE (werkstroom Brand Voice extractie 2026-05-06)
// =============================================================
//
// Parallel module aan Brandstyle (visueel). BrandVoiceguide = verbale identity:
// references, vocabulary, channel-tones, anti-patterns, voice-DNA.
// Gemigreerd uit BrandPersonality.frameworkData voice-velden.
//
// NB: model heet BrandVoiceguide (niet BrandVoice) omdat BrandVoice al
// bestaat als ElevenLabs TTS voice-record (Fase I.1). Voiceguide spiegelt
// BrandStyleguide-naamgeving (visual = styleguide, verbal = voiceguide).
//
// Sequencing: 3-6 maand soft-migration window. Tijdens window blijven
// BrandPersonality voice-velden bestaan; getBrandContext() prefereert
// BrandVoiceguide als bestaat, fallback op BrandPersonality.
//
// Centroid embedding: pgvector(1536) via OpenAI text-embedding-3-small.
// Berekend uit writingSamples[] bij mutatie (background-job).
// =============================================================

model BrandVoiceguide {
  id          String    @id @default(cuid())
  workspaceId String    @unique
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  // ─── Voice DNA ──────────────────────────────
  /**
   * Vrije-tekst beschrijving van de merkstem. Migreert uit BrandPersonality.brandVoiceDescription.
   */
  voiceDescription String? @db.Text

  /**
   * Globale 4-axis NN/g tone-baseline. Shape: { formalCasual, seriousFunny, respectfulIrreverent, matterOfFactEnthusiastic }
   */
  toneDimensions Json?

  /**
   * Content-niveau guidelines voor hoe het merk schrijft. Verhuisd van BrandStyleguide
   * (ADR 2026-05-15). Strings mogen prefix `OBSERVED:` of `RECOMMENDED:` bevatten voor
   * provenance-badges in UI.
   */
  contentGuidelines String[]

  /**
   * Schrijfstijl-regels (zinsbouw, leesbaarheid, etc.). Verhuisd van BrandStyleguide
   * (ADR 2026-05-15). OBSERVED/RECOMMENDED prefix-conventie identiek aan contentGuidelines.
   */
  writingGuidelines String[]

  /** DTS-plan C1 — vocabulary-rails: woorden/zinnen die het merk wel/niet gebruikt.
   *  Variant-generator system-prompt injecteert deze als brand-voice discipline. */
  vocabularyDo   String[] @default([])
  vocabularyDont String[] @default([])

  /** DTS-plan C2 — voice-sample: 40-80 word paragraph in eigen brand-voice
   *  (uit gescrapede bodyText door AI Phase 3). Variant-generator gebruikt
   *  als few-shot example "match this rhythm". */
  voiceSample String? @db.Text

  // ─── References ─────────────────────────────
  /**
   * Gecureerde writing-samples (5-10 typisch). Bron voor centroid-embedding.
   * Migreert van BrandPersonality.writingSample (1×) naar array.
   */
  writingSamples Json @default("[]")

  // ─── Vocabulary ─────────────────────────────
  /**
   * Single-word level — woorden die het merk gebruikt.
   */
  wordsWeUse   String[]
  /**
   * Single-word level — woorden die het merk vermijdt. Auto-sync bron voor BrandRule.
   */
  wordsWeAvoid String[]

  // ─── Channel-Tones ──────────────────────────
  /**
   * Per-kanaal tone-overrides bovenop globale toneDimensions.
   * Shape: { website: { formalCasual, ... }, socialMedia: {...}, email: {...}, ads: {...}, video: {...} }
   */
  channelTones Json?

  // ─── Anti-Patterns ──────────────────────────
  /**
   * Multi-word phrases die het merk vermijdt (uitbreiding op wordsWeAvoid).
   */
  antiPatterns String[]

  /**
   * Do/Don't fraserings-voorbeelden. Verhuisd van BrandStyleguide.examplePhrases
   * (ADR 2026-05-15). Shape: { text: string; type: 'do' | 'dont' }[].
   */
  examplePhrases Json?

  // ─── Embedding centroid (Pijler 1 fidelity) ─────
  /**
   * OpenAI text-embedding-3-small van geconcateneerde writingSamples. Beheerd via raw SQL.
   */
  centroidEmbedding  Unsupported("vector(1536)")?
  centroidComputedAt DateTime?

  // ─── Locale (ADR-3 — per-brand routing voor heuristiek-pakketten) ─────
  /**
   * IETF BCP 47 locale-tag: `nl-NL` / `nl-BE` / `en-GB` / `de-DE` (v1).
   * Wanneer null: `getHeuristicsForBrand()` resolver valt terug op
   * `Workspace.contentLanguage` mapped naar default-locale (en→en-GB,
   * nl→nl-NL, de→de-DE), dan op `en-GB` als ultimate default.
   * Source-of-truth voor F-VAL Pijler 3 heuristiek-pakket-selectie + Δ-2
   * heuristics-packages-multilingual task.
   */
  contentLocale String?

  // ─── Save-for-AI per sectie ──────────────────
  voiceDnaSavedForAi       Boolean @default(true)
  vocabularySavedForAi     Boolean @default(true)
  channelTonesSavedForAi   Boolean @default(true)
  antiPatternsSavedForAi   Boolean @default(true)
  /**
   * Content + writing guidelines (Voice DNA tab). Verhuisd van BrandStyleguide.toneSavedForAi
   * (ADR 2026-05-15). Default true — actief meegenomen in AI-context na consolidatie.
   */
  guidelinesSavedForAi     Boolean @default(true)
  /**
   * Do/Don't examples (Vocabulary tab). Verhuisd van BrandStyleguide.toneSavedForAi gesplitst.
   */
  examplePhrasesSavedForAi Boolean @default(true)
  /**
   * References zijn verbose — default off.
   */
  referencesSavedForAi     Boolean @default(false)

  // ─── Metadata ────────────────────────────────
  /**
   * "manual" | "extracted" (van BrandPersonality migratie) | "analyzer" (door tekst-scanner)
   */
  source      String    @default("manual")
  publishedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation("BrandVoiceguideCreator", fields: [createdById], references: [id])

  @@index([workspaceId])
}

/**
 * Per-type fidelity threshold (content-test #6.B).
 * Workspaces kunnen per content-type een eigen drempel zetten; ontbreken
 * van een record betekent fallback op global default (65, conservatief
 * startend per beslissing 2026-05-12). DeliverableType is in-code
 * registry (geen Prisma FK) — contentTypeId is plain String.
 */
model WorkspaceContentTypeThreshold {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /** Matches DeliverableTypeDefinition.id (zie src/features/campaigns/lib/deliverable-types.ts). */
  contentTypeId String

  /** Composite F-VAL threshold 0-100. Default 65. */
  threshold Int @default(65)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, contentTypeId])
  @@index([workspaceId])
}

// =============================================================
// Brandclaw — Strategy Analyst foundation (ADR 2026-05-08)
// =============================================================
// Immutable point-in-time inputs voor agent-reasoning. Elke
// StrategyAnalyst-run materializeert de data die de agent zag in
// DataSnapshot-rijen zodat past observations reproduceerbaar zijn
// nadat live tables muteren. Payload is JSON-serialized; large
// content-text wordt afgeknipt met char-offset voor herleidbaarheid.
//
// SourceType waarden (v1): 'alignment_scan' / 'content_fidelity' /
// 'review_log' / 'voiceguide'. Uitbreiding zonder schema-migration
// — gewoon een nieuwe source-accessor toevoegen aan de registry.
// =============================================================

model DataSnapshot {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// Source-type identifier. Geen DB-enum zodat nieuwe sources zonder
  /// migration kunnen worden toegevoegd; validation via TS-union in
  /// data-source-registry.
  sourceType String

  /// ID van de live-row die werd gesnapshot. Niet FK want source-type
  /// bepaalt welk model dit is — registry routeert.
  sourceId String

  /// Immutable copy van source-data op snapshot-moment.
  payload Json

  snapshotAt DateTime @default(now())

  @@index([workspaceId, sourceType, snapshotAt])
  @@index([sourceType, sourceId])
}

// =============================================================
// Brandclaw — Strategy Observations (ADR 2026-05-08)
// =============================================================
// Versioned + immutable agent-output. Elke observation is gestempeld
// met agentVersion + promptVersion zodat drift-detection en
// A/B-testing van prompt-changes mogelijk zijn over tijd. Evidence-
// veld linkt DataSnapshot-rijen die de redenering ondersteunden,
// waardoor past observations point-in-time reproduceerbaar zijn.
// =============================================================

enum ObservationSeverity {
  HIGH
  MEDIUM
  LOW
}

enum ObservationConfidence {
  HIGH
  MEDIUM
  LOW
}

model StrategyObservation {
  id          String @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  runId String
  run   StrategyObservationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  /// Observation-dimensie: 'voice_drift' / 'fidelity_decline' /
  /// 'review_pattern' / 'alignment_gap' / future dimensies. Plain TEXT
  /// zodat nieuwe dimensies geen migration vereisen.
  dimension String

  severity   ObservationSeverity
  /// Two-reasons-toets (methodology §11) confidence.
  confidence ObservationConfidence

  summary  String @db.Text
  /// Citation-keys naar DataSnapshot rows + tool-call-trace.
  /// Shape: { snapshotIds: string[]; toolCalls?: Array<{name,inputHash}> }.
  evidence Json

  /// Semver van Analyst-implementatie. Drift-detection over tijd.
  agentVersion  String
  /// Hash of versie-tag van system-prompt. A/B-testing handvat.
  promptVersion String

  createdAt DateTime @default(now())

  /// User-flag: observation is gelezen door owner.
  markedReadAt  DateTime?
  /// User-flag: gebruiker heeft het probleem extern opgelost.
  markedActedAt DateTime?
  /// User-flag: observation gemarkeerd als niet-relevant of false-positive.
  /// Sluit aan op confidence-calibration roadmap (LATER).
  dismissedAt   DateTime?
  /// Optionele reason — voedt promptVersion-iteration cycle.
  dismissReason String?

  @@index([workspaceId, createdAt])
  @@index([workspaceId, dimension])
  @@index([workspaceId, dismissedAt])
  @@index([runId])
}

model StrategyObservationRun {
  id          String @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// 'manual' / 'scheduled' / 'event_driven'. Plain TEXT zodat nieuwe
  /// triggers (bv. 'webhook') zonder migration kunnen worden toegevoegd.
  triggerType String
  /// User-id voor manual-runs, cron-name voor scheduled, event-id voor
  /// event-driven. NULL bij autonomous startup-runs.
  triggerSource String?

  agentVersion  String
  promptVersion String

  /// Sequence van tool-calls + results voor audit + replay.
  /// Shape: Array<{ name, input, result, latencyMs, errorCode? }>.
  toolCallTrace Json

  /// Total Anthropic-API cost (input+output tokens × model-pricing).
  totalCostUsd Decimal @db.Decimal(10, 6)
  /// Wall-clock duration agent-loop start → end.
  latencyMs    Int

  createdAt DateTime @default(now())

  observations StrategyObservation[]

  @@index([workspaceId, createdAt])
  @@index([triggerType])
}

// ─── Web-page builder MVP (per ADR 2026-05-22-landing-page-builder-architectuur) ───

/**
 * Snapshot van een gepubliceerde web-page (landing-page / product-page /
 * faq-page / comparison-page / microsite). Immutable per slug-versie zodat
 * de live URL stabiel rendert ook al wordt de bron-deliverable in Canvas
 * verder bewerkt. Pattern volgt CompetitorSnapshot-ADR (immutable snapshots
 * voor publieke artefacten).
 */
model LandingPage {
  id            String      @id @default(cuid())
  workspaceId   String
  deliverableId String
  /// URL-slug binnen workspace-subdomain — `<slug>` in `<workspace>.branddock.app/<slug>`.
  slug          String
  /// Frozen Puck data-tree snapshot bij publish-tijd. Shape: `Data<SpikePuckProps>`
  /// (Puck core types). Niet gemuteerd na publish — verdere edits leven op
  /// de bron-deliverable.settings.puckData totdat user opnieuw publisht.
  puckData      Json
  status        PageStatus  @default(DRAFT)
  publishedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, slug])
  @@index([workspaceId, status])
  @@index([deliverableId])
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

/**
 * Custom-domain registratie voor een workspace. Phase 1 schema-only (v2-feature
 * activeert provisioning via Vercel Domains API). `domain` is globally unique
 * zodat we tijdens host-resolution in middleware één DB-lookup doen.
 */
model DomainMapping {
  id             String    @id @default(cuid())
  workspaceId    String
  /// Volledige hostname zoals `pages.klant.nl` — globally unique.
  domain         String    @unique
  verifiedAt     DateTime?
  sslStatus      SslStatus @default(PENDING)
  /// Vercel Domains API record-id voor revoke/refresh. Null tot v2-flow.
  vercelDomainId String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

enum SslStatus {
  PENDING
  PROVISIONING
  ACTIVE
  FAILED
}
