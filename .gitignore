# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/e2e/test-results.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev-server.log

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
backups/
lighthouse-report.json

# Local storage provider artefacts (AI-generated images / videos /
# uploads) — never belong in git. Use a real storage provider for prod.
public/uploads/

# Local-only one-shot experiment artefacts die niet in repo horen.
# Bestaande tracked experiment-rapporten in docs/experiments/ blijven
# tracked; deze patterns vangen alleen niet-gecommitte exploratory dumps.
scripts/experiments/gpt-image-2-retest-*
docs/experiments/*-gpt-image-2-retest.json

# LP fidelity baseline-recompute lokale backups (audit 2026-06-10)
scripts/dev/.backup-lp-fidelity-baseline-*.json

# Browser-smoke screenshots (artefacten, niet voor git)
test-screenshots/
