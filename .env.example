# === REQUIRED ===
DATABASE_URL="postgresql://user:password@localhost:5432/branddock"
BETTER_AUTH_SECRET="generate-with: openssl rand -base64 32"
BETTER_AUTH_URL="http://localhost:3000"
# Master key for OAuth-token field encryption (9.6 M10). Must decode to
# 32 bytes. Required in production (fail-closed); optional locally —
# leaving it empty stores tokens as plaintext with a dev-warning.
# Losing this key makes existing OAuth sessions unrecoverable.
#   generate-with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=""

# === AI PROVIDERS (needed for AI features) ===
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# === OPTIONAL: Transactional email (Emailit) ===
# When EMAILIT_API_KEY is missing, email send is a dev-mode no-op (payload
# is logged so you can still inspect invite / reset URLs in the terminal).
# NOTE: Emails are sent from the shared BetterBrands sending domain
# (email.betterbrands.nl) because that's the verified domain in Emailit.
# The EMAILIT_FROM_NAME controls the display name shown to recipients.
EMAILIT_API_KEY=""                                  # From https://app.emailit.com (workspace > API keys)
EMAILIT_FROM_EMAIL="branddock@email.betterbrands.nl"  # Must be a verified sending domain in Emailit
EMAILIT_FROM_NAME="Branddock"
EMAILIT_REPLY_TO=""                                 # Optional; defaults to EMAILIT_FROM_EMAIL
EMAILIT_WEBHOOK_SECRET=""                           # Shared secret for HMAC-SHA256 verification

# === OPTIONAL: TTS / Audio ===
ELEVENLABS_API_KEY=""

# === OPTIONAL: AI Model Training + Video Generation (fal.ai) ===
FAL_KEY=""                         # From https://fal.ai/dashboard/keys

# === OPTIONAL: Stock Media ===
PEXELS_API_KEY=""                  # From https://www.pexels.com/api/

# === OPTIONAL: Redis (production / multi-instance) ===
# When set, rate-limiter + Better Auth session cache use Upstash Redis
# instead of in-memory. Required for Vercel multi-instance deploys.
UPSTASH_REDIS_REST_URL=""          # From https://console.upstash.com
UPSTASH_REDIS_REST_TOKEN=""

# === OPTIONAL: Agent Job Queue (4.4) ===
# CRON_SECRET protects /api/cron/run-jobs — Vercel Cron sends it as
# `Authorization: Bearer <secret>`. In dev without this set, the
# endpoint is open; in production it is required.
CRON_SECRET=""
# WEBHOOK_TRIGGER_SECRET protects /api/webhooks/trigger/<type>.
# External services (n8n, Zapier, etc.) include the same Bearer token.
WEBHOOK_TRIGGER_SECRET=""

# === OPTIONAL: Analytics (PostHog — 4.5 Feedback Engine) ===
# When set, server-side events (agent_job_completed, deliverable_
# approval_changed, campaign_send_completed, etc.) are captured for
# later analysis. Leave empty to disable analytics locally.
POSTHOG_API_KEY=""                 # Project API key from https://eu.posthog.com
POSTHOG_HOST="https://eu.i.posthog.com"  # EU instance; change to https://us.i.posthog.com for US

# === OPTIONAL ENRICHMENT ===
ARENA_API_TOKEN=""
EXA_API_KEY=""
S2_API_KEY=""                      # Semantic Scholar — unauthenticated requests also work

# === OPTIONAL: OAuth Social Login ===
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# MICROSOFT_TENANT_ID=""   # default: 'common'
# APPLE_CLIENT_ID=""
# APPLE_CLIENT_SECRET=""

# === DEVELOPER ACCESS ===
DEVELOPER_EMAILS=""  # Comma-separated, e.g. "dev@example.com,admin@example.com"

# === BILLING (Stripe) ===
NEXT_PUBLIC_BILLING_ENABLED="false"  # false = all free; true = plan enforcement
STRIPE_SECRET_KEY=""                  # sk_test_... (dev) / sk_live_... (prod)
STRIPE_PUBLISHABLE_KEY=""             # pk_test_... (dev) / pk_live_... (prod)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # zelfde als STRIPE_PUBLISHABLE_KEY, exposed naar client
STRIPE_WEBHOOK_SECRET=""              # whsec_...
# Stripe Price IDs (create in Stripe Dashboard)
# STRIPE_PRICE_PRO_MONTHLY=""
# STRIPE_PRICE_AGENCY_MONTHLY=""
# STRIPE_PRICE_ENTERPRISE_MONTHLY=""
# STRIPE_PRICE_AI_OVERAGE=""

# === ERROR TRACKING (Sentry — productie) ===
# NEXT_PUBLIC_SENTRY_DSN enables Sentry server + client error tracking.
# Build picks up Sentry config automatisch via next.config.ts wrapper.
# Source-map upload vereist alle 3 SENTRY_* vars; bij ontbrekende
# SENTRY_AUTH_TOKEN wordt source-map upload geskipt.
NEXT_PUBLIC_SENTRY_DSN=""             # https://...@sentry.io/...
SENTRY_AUTH_TOKEN=""                  # voor source-map upload
SENTRY_ORG=""                         # bv. branddock
SENTRY_PROJECT=""                     # bv. branddock-web
# SENTRY_TEST_SECRET protect /api/test/sentry-trigger endpoint in
# productie. Gebruik om een synthetische error te triggeren en te
# verifieren dat Sentry events ontvangt.
SENTRY_TEST_SECRET=""

# === OBJECT STORAGE (R2 — productie uploads) ===
# In dev gebruikt Branddock local filesystem (public/uploads/).
# In productie moet R2 of equivalent object-storage geconfigureerd zijn.
R2_ACCOUNT_ID=""                      # Cloudflare account ID
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""                     # bv. branddock-media (default 'branddock-media' als leeg)
R2_PUBLIC_URL=""                      # volledige CDN-base-URL, bv. https://assets.branddock.com

# === Google Vision API (image-quality-chain Pattern E) ===
# OCR-detectie voor tekst-in-image post-gen. Detecteert hallucinated copy/
# logo-letters in gegenereerde images en flagt die als textAccuracy-driver.
# Aanvragen via https://console.cloud.google.com/apis/library/vision.googleapis.com
# Optioneel — zonder key draait Pattern E in skip-modus (visual-ai-judge
# text-in-image dimensie blijft werken als vangnet).
GOOGLE_VISION_API_KEY=""              # bv. AIza...
