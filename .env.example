# =============================================================
# Branddock — Environment Variables
# Copy this file to .env.local and fill in the values.
# =============================================================

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/branddock

# ─── Better Auth ────────────────────────────────────────────
BETTER_AUTH_SECRET=   # Generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000

# ─── AI Providers ───────────────────────────────────────────
OPENAI_API_KEY=       # Required for content generation
ANTHROPIC_API_KEY=    # Required for AI Exploration + persona chat (Claude Sonnet 4.6)
GEMINI_API_KEY=       # Optional, for AI photo generation (fallback: DiceBear)
# BRANDDOCK_AI_MODEL= # Default: gpt-4o (content), Claude Sonnet 4.6 (exploration)

# ─── Upstash Redis (Rate Limiting) ─────────────────────────
# Optional: falls back to in-memory if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Cloudflare R2 (File Storage) ──────────────────────────
# Optional: falls back to local paths / data URIs if not set
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=branddock-uploads
R2_PUBLIC_URL=        # e.g. https://uploads.branddock.com

# ─── Resend (Email) ────────────────────────────────────────
# Optional: falls back to console logging if not set
RESEND_API_KEY=
RESEND_FROM_EMAIL=Branddock <noreply@branddock.com>

# ─── Stripe (Billing) ──────────────────────────────────────
# Optional: billing features disabled if not set
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_BILLING_ENABLED=false

# ─── OAuth (Optional) ──────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# ─── Cron Jobs ──────────────────────────────────────────────
# CRON_SECRET=        # For securing cron endpoints
